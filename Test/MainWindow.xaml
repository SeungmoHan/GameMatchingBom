<hc:Window x:Class="Test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="팀뽑기툴" Height="500" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
            <ColumnDefinition Width="1*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"></RowDefinition>
                    <RowDefinition Height="1*"></RowDefinition>
                </Grid.RowDefinitions>
                <ListView x:Name="lvTeamResult" ItemsSource="{Binding Matches}" Grid.Row="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="레드팀" DisplayMemberBinding="{Binding RedMember}" Width="200"/>
                            <GridViewColumn Header="블루팀" DisplayMemberBinding="{Binding BlueMember}" Width="200"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <ListView Grid.Row="1" x:Name="lvRemainPeople" ItemsSource="{Binding User}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="버림받은 사람" DisplayMemberBinding="{Binding NickName}"></GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Grid>
        <Grid Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="5*"></RowDefinition>
                <RowDefinition Height="1*"></RowDefinition>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <DockPanel HorizontalAlignment="Center" Width="200">
                    <Button Content="추가" Click="btnAddPeople" Background="DarkGray" HorizontalAlignment="Center"></Button>
                    <Button Content="제거" Click="btnRemovePeople" Background="DarkGray" HorizontalAlignment="Center"></Button>
                    <Button Content="리셋" Click="btnResetPeople" Background="DarkGray" HorizontalAlignment="Center"></Button>
                </DockPanel>
                <TextBox Text="이름 추가" x:Name="tbNameAdd" GotFocus="tbNameGotFocus"></TextBox>
            </StackPanel>
            <DataGrid x:Name="dgPeople"  Grid.Row="1" 
                      ItemsSource="User"
                      IsReadOnly="True" 
                      SelectionMode="Single"
                      PreviewMouseDoubleClick="dgPreviewMouseDoubleClick" 
                      PreviewMouseDown="dgPreviewMouseDown">
            </DataGrid>
            <Button Grid.Row="2" Content="매칭 시작" Width="180" Height="40" Click="btnShuffleClick">
            </Button>
        </Grid>
        <StackPanel Grid.Column="2">
            <TextBlock Width="200" Height="50" Text="검색하세염" FontSize="30" FontWeight="ExtraBold" TextAlignment="Center"></TextBlock>
            <TextBox x:Name="txtSearch" Width="200" KeyUp="txtSearchKeyUp" />
            <ListBox x:Name="lstSuggestions" Width="200" Height="300" 
                     Visibility="Collapsed" MouseDoubleClick="lstSuggestionsMouseDoubleClick"/>
        </StackPanel>
    </Grid>
</hc:Window>
